# =============================================================================
# LA BROCANTE DU SUD - Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DONNÉES (Supabase PostgreSQL)
# Récupérez ces URLs dans votre projet Supabase > Settings > Database
# DATABASE_URL  : Transaction pooler (port 6543) avec ?pgbouncer=true — utilisé par l'app
# DIRECT_URL    : Session pooler (port 5432) sans pgbouncer — utilisé par prisma db push
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# NEXTAUTH (Authentification admin)
# NEXTAUTH_SECRET : générez avec `openssl rand -base64 32`
# NEXTAUTH_URL : URL de votre site en production
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET="votre-secret-aleatoire-32-caracteres"
NEXTAUTH_URL="https://votre-domaine.com"

# Identifiants admin (changez ces valeurs !)
ADMIN_EMAIL="admin@labrocantedusud.fr"
ADMIN_PASSWORD="MotDePasseSecurise123!"

# -----------------------------------------------------------------------------
# STRIPE (Paiement)
# Récupérez vos clés dans votre Dashboard Stripe > Développeurs > Clés API
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# Webhook Stripe : créez un endpoint dans Stripe > Développeurs > Webhooks
# URL : https://votre-domaine.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# -----------------------------------------------------------------------------
# CLOUDINARY (Images)
# Récupérez ces informations dans votre Dashboard Cloudinary
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME="votre-cloud-name"
CLOUDINARY_API_KEY="votre-api-key"
CLOUDINARY_API_SECRET="votre-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="votre-cloud-name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="brocante-uploads"

# -----------------------------------------------------------------------------
# RESEND (Emails transactionnels)
# Créez un compte sur resend.com et générez une clé API
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_..."
# Email expéditeur (doit être un domaine vérifié dans Resend)
EMAIL_FROM="La Brocante de Nanie <noreply@labrocantedenanie.com>"
# Email de contact pour les formulaires
EMAIL_CONTACT="contact@labrocantedenanie.com"

# -----------------------------------------------------------------------------
# SITE
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="https://votre-domaine.com"
NEXT_PUBLIC_SITE_NAME="La Brocante du Sud"
